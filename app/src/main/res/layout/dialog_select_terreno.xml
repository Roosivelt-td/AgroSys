<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_bg"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="32dp">

    <View
        android:layout_width="48dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:alpha="0.3"
        android:background="#6B7280" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Dónde sembraremos?"
                android:textColor="#111827"
                android:textSize="24sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Escoge el terreno para el nuevo cultivo"
                android:textColor="#6B7280"
                android:textSize="14sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnCloseDialog"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_bg_gray_light"
            android:padding="12dp"
            android:src="@drawable/ic_close"
            app:tint="#4B5563" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTerrenosSelector"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:overScrollMode="never" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmarSeleccion"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Confirmar y Continuar"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        app:backgroundTint="#15803d"
        app:cornerRadius="20dp"
        app:elevation="4dp"
        android:enabled="false"
        app:icon="@drawable/ic_check"
        app:iconGravity="textStart"
        app:iconPadding="12dp" />

</LinearLayout>
