<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00582a">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#00582a"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/header_gradient_bg"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/direccion_izquierda"
                    app:tint="#ffffff"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHeaderLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_registro_de"
                        android:textColor="#dcfce7"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvHeaderTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/header_nuevo_terreno"
                        android:textColor="#ffffff"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/circle_bg_green_light"
                    android:padding="8dp"
                    android:src="@drawable/ic_ubicacion_terreno"
                    app:tint="#15803d" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:id="@+id/scroll_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:isScrollContainer="true">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="40dp"
                app:cardElevation="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Card.TopOnly">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Nombre -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_nombre_terreno"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/edit_text_elegant"
                    android:hint="@string/hint_nombre_terreno"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:inputType="textCapSentences"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:imeOptions="actionNext" />

                <!-- Ubicación -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_ubicacion_direccion"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/etUbicacion"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/edit_text_elegant"
                    android:hint="@string/hint_ubicacion_direccion"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:imeOptions="actionNext" />

                <!-- Área -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_area_hectareas"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp">
                    <EditText
                        android:id="@+id/etArea"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/edit_text_elegant"
                        android:hint="@string/hint_area_hectareas"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:paddingEnd="48dp"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:imeOptions="actionNext" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:text="@string/unit_ha"
                        android:textColor="#6B7280" />
                </FrameLayout>

                <!-- Tenencia -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_tipo_tenencia"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleTenencia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:checkedButton="@+id/btnPropio"
                    app:selectionRequired="true"
                    app:singleSelection="true">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPropio"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_propio"
                        android:textAllCaps="false" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAlquilado"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_alquilado"
                        android:textAllCaps="false" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- Costo Alquiler (Visible solo si Alquilado) -->
                <LinearLayout
                    android:id="@+id/layoutCosto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_costo_alquiler"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/etCostoAlquiler"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/edit_text_elegant"
                        android:hint="@string/hint_costo_alquiler"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:imeOptions="actionNext" />
                </LinearLayout>

                <!-- Calidad Suelo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_calidad_suelo"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/etCalidadSuelo"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/edit_text_elegant"
                    android:hint="@string/hint_calidad_suelo"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:imeOptions="actionNext" />

                <!-- Fuente Agua -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_fuente_agua"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/etFuenteAgua"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/edit_text_elegant"
                    android:hint="@string/hint_fuente_agua"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:imeOptions="actionDone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="#BD22C1"
                    android:text="@string/btn_guardar_terreno"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:elevation="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:paddingBottom="40dp"
                    android:gravity="center"
                    android:text="@string/footer_datos_locales"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />

            </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </ScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>