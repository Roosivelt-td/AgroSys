<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2EE"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/header_gradient"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="15dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/direccion_derecha"
                app:tint="@android:color/white"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nuevo Terreno"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registra un terreno agrícola"
                    android:textColor="#CCFFCC"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_bg_green_light"
                android:backgroundTint="#33FFFFFF"
                android:padding="8dp"
                android:src="@android:drawable/ic_dialog_map"
                app:tint="@android:color/white" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Nombre -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre del terreno *"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/edit_text_elegant"
                    android:hint="Ej: Fundo La Esperanza"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp" />

                <!-- Ubicación -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Ubicación / Dirección"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/etUbicacion"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/edit_text_elegant"
                    android:hint="Ej: Km 12 Carretera Piura"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp" />

                <!-- Área -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Área (hectáreas) *"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp">
                    <EditText
                        android:id="@+id/etArea"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/edit_text_elegant"
                        android:hint="Ej: 5.5"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:paddingEnd="48dp"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:text="ha"
                        android:textColor="#6B7280" />
                </FrameLayout>

                <!-- Tenencia -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Tipo de tenencia *"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleTenencia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:checkedButton="@+id/btnPropio"
                    app:selectionRequired="true"
                    app:singleSelection="true">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPropio"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Propio"
                        android:textAllCaps="false" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAlquilado"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Alquilado"
                        android:textAllCaps="false" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- Costo Alquiler (Visible solo si Alquilado) -->
                <LinearLayout
                    android:id="@+id/layoutCosto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Costo de alquiler anual (S/.)"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/etCostoAlquiler"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/edit_text_elegant"
                        android:hint="Ej: 2500.00"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Calidad Suelo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Calidad del suelo"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/etCalidadSuelo"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/edit_text_elegant"
                    android:hint="Ej: buena, regular, mala, intermedia, otro... "
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp" />

                <!-- Fuente Agua -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Fuente de agua"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/etFuenteAgua"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/edit_text_elegant"
                    android:hint="Ej: Canal de riego, Aspersion, Goteo"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="#166534"
                    android:text="Guardar terreno"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:elevation="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:text="🛡 Los datos se guardarán localmente"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>