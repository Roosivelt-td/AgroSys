<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#eef2ee">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient_bg"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@drawable/direccion_izquierda"
                app:tint="#ffffff"
                android:rotation="180"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_toEndOf="@id/btnBack"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registrar Labor"
                    android:textColor="#ffffff"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHeaderSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selecciona una labor para comenzar"
                    android:textColor="#dcfce7"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/circle_bg_green_light"
                android:padding="8dp"
                android:src="@drawable/ic_lista"
                app:tint="#15803d" />
        </RelativeLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Cultivo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cultivo *"
                android:textColor="#374151"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerCultivos"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_elegant" />

            <!-- Tipo de labor (Grid) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Tipo de labor *"
                android:textColor="#374151"
                android:textStyle="bold" />

            <GridLayout
                android:id="@+id/laboresGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="3"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <!-- 1. Preparación -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPreparacion"
                    style="@style/LaborCardStyle">
                    <LinearLayout style="@style/LaborCardContentStyle">
                        <ImageView android:src="@drawable/ic_tractor" style="@style/LaborIconStyle" />
                        <TextView android:text="Preparación" style="@style/LaborTextStyle" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2. Siembra -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSiembra"
                    style="@style/LaborCardStyle">
                    <LinearLayout style="@style/LaborCardContentStyle">
                        <ImageView android:src="@drawable/ic_planta_01" style="@style/LaborIconStyle" />
                        <TextView android:text="Siembra" style="@style/LaborTextStyle" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3. Riego -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRiego"
                    style="@style/LaborCardStyle">
                    <LinearLayout style="@style/LaborCardContentStyle">
                        <ImageView android:src="@drawable/ic_planta_hoja" style="@style/LaborIconStyle" />
                        <TextView android:text="Riego" style="@style/LaborTextStyle" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 4. Fumigación -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFumigacion"
                    style="@style/LaborCardStyle">
                    <LinearLayout style="@style/LaborCardContentStyle">
                        <ImageView android:src="@drawable/ic_alerta" style="@style/LaborIconStyle" />
                        <TextView android:text="Fumigación" style="@style/LaborTextStyle" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 5. Aporque -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAporque"
                    style="@style/LaborCardStyle">
                    <LinearLayout style="@style/LaborCardContentStyle">
                        <ImageView android:src="@drawable/ic_ubicacion_terreno" style="@style/LaborIconStyle" />
                        <TextView android:text="Aporque" style="@style/LaborTextStyle" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 6. Deshierbe -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDeshierbe"
                    style="@style/LaborCardStyle">
                    <LinearLayout style="@style/LaborCardContentStyle">
                        <ImageView android:src="@drawable/ic_plata_marchitada" style="@style/LaborIconStyle" />
                        <TextView android:text="Deshierbe" style="@style/LaborTextStyle" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 7. Fertilización -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFertilizacion"
                    style="@style/LaborCardStyle">
                    <LinearLayout style="@style/LaborCardContentStyle">
                        <ImageView android:src="@drawable/ic_planta_buena" style="@style/LaborIconStyle" />
                        <TextView android:text="Fertilización" style="@style/LaborTextStyle" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 8. Cosecha -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCosecha"
                    style="@style/LaborCardStyle">
                    <LinearLayout style="@style/LaborCardContentStyle">
                        <ImageView android:src="@drawable/ic_cosecha" style="@style/LaborIconStyle" />
                        <TextView android:text="Cosecha" style="@style/LaborTextStyle" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 9. Otro -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardOtro"
                    style="@style/LaborCardStyle">
                    <LinearLayout style="@style/LaborCardContentStyle">
                        <ImageView android:src="@drawable/ic_lista" style="@style/LaborIconStyle" />
                        <TextView android:text="Otro" style="@style/LaborTextStyle" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Form Container (Hidden until selection) -->
            <LinearLayout
                android:id="@+id/formContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Fecha -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Fecha de realización *"
                    android:textColor="#374151"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etFechaRealizacion"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/edit_text_elegant"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="dd/mm/aaaa"
                    android:paddingHorizontal="16dp" />

                <!-- Descripción -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Descripción"
                    android:textColor="#374151"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etObservaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/edit_text_elegant"
                    android:gravity="top"
                    android:hint="Notas sobre la labor..."
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:padding="16dp" />

                <!-- Mano de Obra y Maquinaria Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCostosBase"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="#F9FAFB"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Mano de Obra Container -->
                        <LinearLayout
                            android:id="@+id/containerManoObra"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Costos de mano de obra"
                                android:textColor="#374151"
                                android:textStyle="bold" />

                            <RadioGroup
                                android:id="@+id/rgTipoJornal"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:orientation="vertical">

                                <RadioButton
                                    android:id="@+id/rbUnificado"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:checked="true"
                                    android:text="Unificado (sin distinción)"
                                    android:textSize="13sp" />

                                <RadioButton
                                    android:id="@+id/rbDiferenciado"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Diferenciado (Hombre/Mujer)"
                                    android:textSize="13sp" />
                            </RadioGroup>

                            <!-- Unificado UI -->
                            <LinearLayout
                                android:id="@+id/llManoObraUnificado"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nº peones" android:textSize="11sp"/>
                                        <EditText android:id="@+id/etPeonesUnif" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/edit_text_elegant" android:inputType="number" android:text="0" android:textSize="14sp" android:paddingHorizontal="12dp" android:layout_marginTop="2dp"/>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginStart="8dp"
                                        android:orientation="vertical">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Días trabajo" android:textSize="11sp"/>
                                        <EditText android:id="@+id/etDiasUnif" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/edit_text_elegant" android:inputType="numberDecimal" android:text="0" android:textSize="14sp" android:paddingHorizontal="12dp" android:layout_marginTop="2dp"/>
                                    </LinearLayout>
                                </LinearLayout>

                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Costo por jornal (S/.)" android:textSize="11sp" android:layout_marginTop="8dp"/>
                                <EditText android:id="@+id/etCostoJornalUnif" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/edit_text_elegant" android:inputType="numberDecimal" android:text="45" android:textSize="14sp" android:paddingHorizontal="12dp" android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <!-- Diferenciado UI -->
                            <LinearLayout
                                android:id="@+id/llManoObraDiferenciado"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Género" android:textSize="10sp" android:textStyle="bold" android:gravity="center"/>
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Cant." android:textSize="10sp" android:textStyle="bold" android:gravity="center"/>
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Días" android:textSize="10sp" android:textStyle="bold" android:gravity="center"/>
                                </LinearLayout>

                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="👨 Hombres" android:textSize="13sp"/>
                                    <EditText android:id="@+id/etHombresCant" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/edit_text_elegant" android:inputType="number" android:text="0" android:gravity="center" android:textSize="13sp" android:layout_margin="2dp"/>
                                    <EditText android:id="@+id/etHombresDias" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/edit_text_elegant" android:inputType="numberDecimal" android:text="0" android:gravity="center" android:textSize="13sp" android:layout_margin="2dp"/>
                                </LinearLayout>

                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="👩 Mujeres" android:textSize="13sp"/>
                                    <EditText android:id="@+id/etMujeresCant" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/edit_text_elegant" android:inputType="number" android:text="0" android:gravity="center" android:textSize="13sp" android:layout_margin="2dp"/>
                                    <EditText android:id="@+id/etMujeresDias" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/edit_text_elegant" android:inputType="numberDecimal" android:text="0" android:gravity="center" android:textSize="13sp" android:layout_margin="2dp"/>
                                </LinearLayout>

                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">
                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jornal hombre" android:textSize="10sp"/>
                                        <EditText android:id="@+id/etJornalHombre" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_elegant" android:inputType="numberDecimal" android:text="50" android:textSize="13sp" android:paddingHorizontal="8dp"/>
                                    </LinearLayout>
                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:orientation="vertical">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jornal mujer" android:textSize="10sp"/>
                                        <EditText android:id="@+id/etJornalMujer" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_elegant" android:inputType="numberDecimal" android:text="45" android:textSize="13sp" android:paddingHorizontal="8dp"/>
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Maquinaria Container -->
                        <LinearLayout
                            android:id="@+id/containerMaquinaria"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Costo de maquinaria (S/.)"
                                android:textColor="#374151"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <EditText
                                android:id="@+id/etCostoMaquinaria"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/edit_text_elegant"
                                android:hint="0.00"
                                android:inputType="numberDecimal"
                                android:paddingHorizontal="12dp"
                                android:text="0"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Insumos Section -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardInsumos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="#F9FAFB"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:text="Insumos utilizados"
                                android:textColor="#374151"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAgregarInsumo"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="+ Agregar"
                                android:textAllCaps="false"
                                android:textColor="#15803d" />
                        </RelativeLayout>

                        <LinearLayout
                            android:id="@+id/insumosContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/tvEmptyInsumos"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:paddingVertical="12dp"
                                android:text="No hay insumos registrados"
                                android:textColor="#9CA3AF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Total Preview y Resumen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/rounded_background"
                android:backgroundTint="#F0FDF4"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvLaboresResumen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No hay labores listas para guardar"
                    android:textColor="#15803d"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"
                    android:textStyle="italic" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="💰 Costo Total Sesión"
                        android:textColor="#374151"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCostoTotalPreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S/ 0.00"
                        android:textColor="#15803D"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnSaveLabor"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#15803d"
                android:text="Registrar todas las labores"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
