<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:fitsSystemWindows="true">

    <!-- Header con info del cultivo -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient_bg"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_centerVertical="true"
                android:background="@drawable/circle_bg_white"
                android:padding="8dp"
                android:src="@drawable/direccion_izquierda"
                app:tint="#15803D" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_toEndOf="@id/btnBack"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre del Terreno"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHeaderSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lote - Variedad"
                    android:textColor="#DCFCE7"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCostoTotalSession"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="S/ 0.00"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/footerActions"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Selector de Labores (Grid) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Selecciona la labor a realizar:"
                android:textColor="#374151"
                android:textSize="14sp"
                android:textStyle="bold" />

            <GridLayout
                android:id="@+id/laboresGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <!-- Reutilizamos los estilos previos pero los haremos más compactos -->
                <!-- Preparación -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPreparacion"
                    style="@style/LaborCardStyle"
                    app:cardCornerRadius="16dp">
                    <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                        <TextView android:id="@+id/tvCountPreparacion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                        <ImageView android:src="@drawable/agro_maquinaria_tractor" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp"/>
                        <TextView android:text="Preparar" style="@style/LaborTextStyle" android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Siembra -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSiembra"
                    style="@style/LaborCardStyle"
                    app:cardCornerRadius="16dp">
                    <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                        <TextView android:id="@+id/tvCountSiembra" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                        <ImageView android:src="@drawable/agro_siembra_03" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp"/>
                        <TextView android:text="Sembrar" style="@style/LaborTextStyle" android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Riego -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRiego"
                    style="@style/LaborCardStyle"
                    app:cardCornerRadius="16dp">
                    <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                        <TextView android:id="@+id/tvCountRiego" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                        <ImageView android:src="@drawable/agua_riego_01" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp"/>
                        <TextView android:text="Riego" style="@style/LaborTextStyle" android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Fumigación (Control de Plagas) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFumigacion"
                    style="@style/LaborCardStyle"
                    app:cardCornerRadius="16dp">
                    <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                        <TextView android:id="@+id/tvCountFumigacion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                        <ImageView android:src="@drawable/agro_quimico_01" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp"/>
                        <TextView android:text="Fumigar" style="@style/LaborTextStyle" android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Aporque -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAporque"
                    style="@style/LaborCardStyle"
                    app:cardCornerRadius="16dp">
                    <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                        <TextView android:id="@+id/tvCountAporque" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                        <ImageView android:src="@drawable/ic_trabajo_01" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp"/>
                        <TextView android:text="Aporque" style="@style/LaborTextStyle" android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Deshierbe -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDeshierbe"
                    style="@style/LaborCardStyle"
                    app:cardCornerRadius="16dp">
                    <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                        <TextView android:id="@+id/tvCountDeshierbe" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                        <ImageView android:src="@drawable/agro_planta_deshierbe" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp"/>
                        <TextView android:text="Deshierbe" style="@style/LaborTextStyle" android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Fertilizacion -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFertilizacion"
                    style="@style/LaborCardStyle"
                    app:cardCornerRadius="16dp">
                    <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                        <TextView android:id="@+id/tvCountFertilizacion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                        <ImageView android:src="@drawable/agro_fertilizar" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp"/>
                        <TextView android:text="Abonar" style="@style/LaborTextStyle" android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Cosecha -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCosecha"
                    style="@style/LaborCardStyle"
                    app:cardCornerRadius="16dp">
                    <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                        <TextView android:id="@+id/tvCountCosecha" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                        <ImageView
                            style="@style/LaborIconStyle"
                            android:layout_width="20dp"
                            android:layout_height="24dp"
                            android:src="@drawable/agro_cosecha_01" />
                        <TextView android:text="Cosechar" style="@style/LaborTextStyle" android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- otros -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPoda"
                    style="@style/LaborCardStyle"
                    app:cardCornerRadius="16dp">
                    <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                        <TextView android:id="@+id/tvCountOtros" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                        <ImageView android:src="@drawable/ic_lista" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp"/>
                        <TextView android:text="Otros" style="@style/LaborTextStyle" android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


            </GridLayout>

            <!-- Lista de Labores Acumuladas -->
            <TextView
                android:id="@+id/tvLaboresListTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="Labor para registrar en esta sesión:"
                android:textColor="#374151"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/llLaboresList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvEmptyLabores"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:gravity="center"
                    android:background="@drawable/rounded_soft"
                    android:backgroundTint="#FFFFFF"
                    android:text="No has agregado labores todavía"
                    android:textColor="#9CA3AF" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Botón de acción principal -->
    <LinearLayout
        android:id="@+id/footerActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnFinalizarRegistro"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#15803D"
            android:text="Confirmar y Guardar Todo"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:enabled="false"
            app:cornerRadius="16dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
