<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f3b1f"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#00582a"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/header_gradient_bg"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/direccion_izquierda"
                    app:tint="#ffffff"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHeaderLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_registro_de"
                        android:textColor="#dcfce7"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvHeaderTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre del Terreno"
                        android:textColor="#ffffff"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHeaderSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detalle del Cultivo"
                        android:textColor="#dcfce7"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/circle_bg_green_light"
                    android:padding="8dp"
                    android:src="@drawable/ic_lista"
                    app:tint="#353A37" />
            </LinearLayout>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="40dp"
                app:cardElevation="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Card.TopOnly">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/white"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Selector de Labores (Grid) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/label_selecciona_labor"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <GridLayout
                        android:id="@+id/laboresGrid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="3"
                        android:alignmentMode="alignMargins"
                        android:columnOrderPreserved="false">

                        <!-- Preparación -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardPreparacion"
                            style="@style/LaborCardStyle"
                            app:cardCornerRadius="16dp">
                            <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                                <TextView android:id="@+id/tvCountPreparacion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#313332" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                                <ImageView android:src="@drawable/agro_maquinaria_tractor" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp" app:tint="#84CC16"/>
                                <TextView android:text="@string/labor_preparar" style="@style/LaborTextStyle" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Siembra -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardSiembra"
                            style="@style/LaborCardStyle"
                            app:cardCornerRadius="16dp">
                            <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                                <TextView android:id="@+id/tvCountSiembra" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                                <ImageView android:src="@drawable/agro_siembra_03" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp" app:tint="#22c55e"/>
                                <TextView android:text="@string/labor_sembrar" style="@style/LaborTextStyle" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Riego -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardRiego"
                            style="@style/LaborCardStyle"
                            app:cardCornerRadius="16dp">
                            <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                                <TextView android:id="@+id/tvCountRiego" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                                <ImageView android:src="@drawable/agua_riego_01" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp" app:tint="#0EA5E9"/>
                                <TextView android:text="@string/labor_riego" style="@style/LaborTextStyle" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Fumigación -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardFumigacion"
                            style="@style/LaborCardStyle"
                            app:cardCornerRadius="16dp">
                            <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                                <TextView android:id="@+id/tvCountFumigacion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                                <ImageView android:src="@drawable/agro_quimico_01" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp" app:tint="#f59e0b"/>
                                <TextView android:text="@string/labor_fumigar" style="@style/LaborTextStyle" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Aporque -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardAporque"
                            style="@style/LaborCardStyle"
                            app:cardCornerRadius="16dp">
                            <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                                <TextView android:id="@+id/tvCountAporque" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                                <ImageView android:src="@drawable/ic_trabajo_01" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp" app:tint="#b45309"/>
                                <TextView android:text="@string/labor_aporque" style="@style/LaborTextStyle" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Deshierbe -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardDeshierbe"
                            style="@style/LaborCardStyle"
                            app:cardCornerRadius="16dp">
                            <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                                <TextView android:id="@+id/tvCountDeshierbe" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                                <ImageView android:src="@drawable/agro_planta_deshierbe" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp" app:tint="#10b981"/>
                                <TextView android:text="@string/labor_deshierbe" style="@style/LaborTextStyle" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Fertilizacion -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardFertilizacion"
                            style="@style/LaborCardStyle"
                            app:cardCornerRadius="16dp">
                            <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                                <TextView android:id="@+id/tvCountFertilizacion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                                <ImageView android:src="@drawable/agro_fertilizar" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp" app:tint="#6366f1"/>
                                <TextView android:text="@string/labor_abonar" style="@style/LaborTextStyle" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Cosecha -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardCosecha"
                            style="@style/LaborCardStyle"
                            app:cardCornerRadius="16dp">
                            <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                                <TextView android:id="@+id/tvCountCosecha" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                                <ImageView
                                    style="@style/LaborIconStyle"
                                    android:layout_width="20dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/agro_cosecha_01"
                                    app:tint="#EAB308"/>
                                <TextView android:text="@string/labor_cosechar" style="@style/LaborTextStyle" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Otros -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardPoda"
                            style="@style/LaborCardStyle"
                            app:cardCornerRadius="16dp">
                            <LinearLayout style="@style/LaborCardContentStyle" android:padding="8dp">
                                <TextView android:id="@+id/tvCountOtros" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#15803D" android:textStyle="bold" android:background="@drawable/circle_bg_white" android:paddingHorizontal="4dp" android:layout_gravity="end"/>
                                <ImageView android:src="@drawable/ic_lista" style="@style/LaborIconStyle" android:layout_width="24dp" android:layout_height="24dp" app:tint="#6b7280"/>
                                <TextView android:text="@string/labor_otros" style="@style/LaborTextStyle" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </GridLayout>

                    <!-- Lista de Labores Acumuladas -->
                    <TextView
                        android:id="@+id/tvLaboresListTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/label_labor_sesion"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Resumen de Costos -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_inversion_estimada"
                            android:textColor="#64748b"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvCostoTotalSession"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S/ 0.00"
                            android:textColor="#15803d"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llLaboresList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvEmptyLabores"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:gravity="center"
                            android:background="@drawable/rounded_soft"
                            android:backgroundTint="#f8fafc"
                            android:text="@string/msg_empty_labores"
                            android:textColor="#9CA3AF" />
                    </LinearLayout>

                    <!-- Botón Guardar (Ahora dentro del flujo del scroll para consistencia) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFinalizarRegistro"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="32dp"
                        android:backgroundTint="#BD22C1"
                        android:text="@string/btn_confirmar_guardar"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:enabled="false"
                        app:cornerRadius="16dp"
                        app:elevation="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:paddingBottom="40dp"
                        android:gravity="center"
                        android:text="@string/footer_datos_locales"
                        android:textColor="#9CA3AF"
                        android:textSize="11sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- Footer container removed as btnFinalizarRegistro is now inside ScrollView for consistency with other screens -->

</androidx.constraintlayout.widget.ConstraintLayout>
