<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f3b1f">

    <!-- Header Moderno con Gradiente -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient_bg"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/direccion_izquierda"
                app:tint="#ffffff" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHeaderLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_detalle_de"
                    android:textColor="#dcfce7"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#ffffff"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Lote 01 - Maiz" />

                <TextView
                    android:id="@+id/tvHeaderVariedad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#dcfce7"
                    android:textSize="13sp"
                    tools:text="Híbrido Dekalb 7088" />
            </LinearLayout>

            <ImageView
                android:id="@+id/btnMasOpciones"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/circle_bg_white"
                android:padding="8dp"
                android:src="@drawable/ic_lista"
                app:tint="#15803d" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/headerContainer">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="40dp"
            app:cardElevation="0dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Card.TopOnly">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#ffffff"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Card Principal: KPI de Campaña -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#ffffff"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@id/tvEstadoBadge"
                            android:layout_marginEnd="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvNombreLote"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#111827"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:text="Lote 01" />

                            <TextView
                                android:id="@+id/tvVariedad"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="#6b7280"
                                android:textSize="14sp"
                                tools:text="Variedad: Maiz Híbrido" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvEstadoBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/chip_bg_green"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="activo"
                            android:textAllCaps="true"
                            android:textColor="#15803d"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Progreso de Campaña -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:id="@+id/tvDiaActual"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#1e293b"
                                android:textStyle="bold"
                                tools:text="Día 45" />

                            <TextView
                                android:id="@+id/tvDiasRestantes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:textColor="#64748b"
                                android:textSize="13sp"
                                tools:text="75 días restantes" />
                        </RelativeLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressCampania"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:progress="35"
                            app:indicatorColor="#15803d"
                            app:trackColor="#f1f5f9"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="8dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="20dp"
                        android:background="#f1f5f9" />

                    <!-- Stats Grid -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_area_lote"
                                android:textColor="#64748b"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvArea"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#1e293b"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                tools:text="2.5 ha" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1.2"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_fecha_siembra"
                                android:textColor="#64748b"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvFechaSiembra"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#1e293b"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                tools:text="15/05/2026" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="0.8"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_labores"
                                android:textColor="#64748b"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvCantLabores"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#1e293b"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                tools:text="8" />
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card de Finanzas: Estilo KPI -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#ffffff"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_resumen_financiero_title"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_costos"
                                android:textColor="#64748b"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvCostosTotales"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#dc2626"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="S/ 4,250" />

                            <!-- Hidden secondary ID for activity compatibility -->
                            <TextView
                                android:id="@+id/tvCostosTotalesCard"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:visibility="gone" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_ingresos"
                                android:textColor="#64748b"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvIngresosTotales"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#15803d"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="S/ 8,000" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_neto"
                                android:textColor="#64748b"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvGanancia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#1e293b"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="S/ 3,750" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="20dp"
                        android:background="#f1f5f9" />

                    <!-- Desglose de Finanzas via include -->
                    <include
                        android:id="@+id/rowPrep"
                        layout="@layout/row_finanzas_detalle" />

                    <include
                        android:id="@+id/rowSiembra"
                        layout="@layout/row_finanzas_detalle" />

                    <include
                        android:id="@+id/rowMant"
                        layout="@layout/row_finanzas_detalle" />

                    <include
                        android:id="@+id/rowCosecha"
                        layout="@layout/row_finanzas_detalle" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Selector de Estado Rápido -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="12dp"
                android:text="@string/label_estado_del_cultivo"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStatusPlanificado"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="@string/label_planificado_short"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStatusActivo"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="@string/label_activo_short"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStatusCosechado"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="@string/label_cosechado_short"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStatusPerdido"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_perdido_short"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Sección de Labores -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvLaboresTitulo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Labores (0)" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAgregarLabor"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_agregar"
                    android:textAllCaps="false"
                    android:textColor="#15803d"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconTint="#15803d" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLabores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_labor_group" />

            <!-- Sección de Cosechas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCosechasTitulo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Cosechas (0)" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAgregarCosecha"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_registrar"
                    android:textAllCaps="false"
                    android:textColor="#15803d"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconTint="#15803d" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCosechas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_cosecha_detalle" />

            <!-- Info Adicional de Terreno -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#e2e8f0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_informacion_terreno"
                        android:textColor="#1e293b"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_area_total_terreno"
                            android:textColor="#64748b"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvAreaTotalTerreno"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:textColor="#1e293b"
                            android:textStyle="bold"
                            tools:text="5.0 ha" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEliminarCultivo"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="#BD22C1"
                    android:text="@string/btn_eliminar_cultivo"
                    android:textAllCaps="false"
                    android:textColor="#ffffff"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_delete"
                    app:iconTint="#ffffff"
                    app:elevation="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingBottom="40dp"
                    android:gravity="center"
                    android:text="@string/footer_datos_locales"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_casa"
                app:tint="#9ca3af" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_inicio"
                android:textSize="10sp"
                android:textColor="#9ca3af" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navTerrenos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_ubicacion_terreno"
                app:tint="#9ca3af" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_terrenos"
                android:textSize="10sp"
                android:textColor="#9ca3af" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCultivos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/agro_planta_buena"
                app:tint="#166534" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_cultivos"
                android:textSize="10sp"
                android:textColor="#166534"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navLabores"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_lista"
                app:tint="#9ca3af" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_labores"
                android:textSize="10sp"
                android:textColor="#9ca3af" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navReportes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_estadistica_01"
                app:tint="#9ca3af" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_reportes"
                android:textSize="10sp"
                android:textColor="#9ca3af" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
