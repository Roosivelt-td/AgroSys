<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8fafc">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient_bg"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/direccion_izquierda"
                app:tint="#ffffff"
                android:rotation="180"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHeaderLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_detalle_de"
                    android:textColor="#dcfce7"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_cargando"
                    android:textColor="#ffffff"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/circle_bg_green_light"
                android:padding="8dp"
                android:src="@drawable/agro_planta_buena"
                app:tint="#15803d" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/header_container">

        <LinearLayout
            android:id="@+id/detalleContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card Principal -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="40dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#d1fae5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#f0fdf4"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvNombreLote"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Papa - Canchan"
                        android:textColor="#1f2937"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTerrenoNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Fundo El Edén"
                        android:textColor="#4b5563"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_area"
                                android:textColor="#6b7280"
                                android:textSize="10sp" />
                            <TextView
                                android:id="@+id/tvArea"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2.0 ha"
                                android:textColor="#111827"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_ganancia"
                                android:textColor="#6b7280"
                                android:textSize="10sp" />
                            <TextView
                                android:id="@+id/tvGanancia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="S/ 0.00"
                                android:textColor="#15803d"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_estado_cultivo"
                                android:textColor="#6b7280"
                                android:textSize="10sp" />
                            <TextView
                                android:id="@+id/tvEstado"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_activo"
                                android:textColor="#111827"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Estados -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/label_estado_del_cultivo"
                android:textColor="#374151"
                android:textSize="14sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="4">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStatusPlanificado"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:text="📋"
                    android:padding="0dp"
                    app:cornerRadius="8dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStatusActivo"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:text="🌱"
                    android:padding="0dp"
                    app:cornerRadius="8dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStatusCosechado"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:text="🍂"
                    android:padding="0dp"
                    app:cornerRadius="8dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStatusPerdido"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:text="⚠️"
                    android:padding="0dp"
                    app:cornerRadius="8dp" />
            </GridLayout>

            <!-- Resumen Financiero -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="40dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#e5e7eb">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_resumen_financiero"
                        android:textColor="#374151"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <!-- Costos totales -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <View android:id="@+id/dotCostos" android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/circle_bg_red" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/dotCostos" android:layout_marginStart="8dp" android:text="@string/label_costos_totales" android:textColor="#6b7280" android:textSize="14sp"/>
                            <TextView android:id="@+id/tvCostosTotales" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="S/ 0" android:textColor="#ef4444" android:textStyle="bold" android:textSize="14sp"/>
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#f3f4f6" android:layout_marginBottom="12dp"/>

                        <!-- Ingresos -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <View android:id="@+id/dotIngresos" android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/circle_bg_green" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/dotIngresos" android:layout_marginStart="8dp" android:text="@string/label_ingresos" android:textColor="#6b7280" android:textSize="14sp"/>
                            <TextView android:id="@+id/tvIngresosTotales" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="S/ 0" android:textColor="#22c55e" android:textStyle="bold" android:textSize="14sp"/>
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#f3f4f6" android:layout_marginBottom="12dp"/>

                        <!-- Preparación -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <View android:id="@+id/dotPrep" android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/circle_bg_purple" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/dotPrep" android:layout_marginStart="8dp" android:text="@string/labor_preparar" android:textColor="#6b7280" android:textSize="14sp"/>
                            <TextView android:id="@+id/tvCostoPreparacion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="S/ 0" android:textColor="#a855f7" android:textStyle="bold" android:textSize="14sp"/>
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#f3f4f6" android:layout_marginBottom="12dp"/>

                        <!-- Siembra -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <View android:id="@+id/dotSiembra" android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/circle_bg_green_light" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/dotSiembra" android:layout_marginStart="8dp" android:text="@string/labor_sembrar" android:textColor="#6b7280" android:textSize="14sp"/>
                            <TextView android:id="@+id/tvCostoSiembra" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="S/ 0" android:textColor="#4ade80" android:textStyle="bold" android:textSize="14sp"/>
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#f3f4f6" android:layout_marginBottom="12dp"/>

                        <!-- Mantenimiento -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <View android:id="@+id/dotMant" android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/circle_bg_blue" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/dotMant" android:layout_marginStart="8dp" android:text="@string/label_mantenimiento" android:textColor="#6b7280" android:textSize="14sp"/>
                            <TextView android:id="@+id/tvCostoMantenimiento" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="S/ 0" android:textColor="#3b82f6" android:textStyle="bold" android:textSize="14sp"/>
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#f3f4f6" android:layout_marginBottom="12dp"/>

                        <!-- Cosecha/Venta -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp">
                            <View android:id="@+id/dotCosecha" android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/circle_bg_orange" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/dotCosecha" android:layout_marginStart="8dp" android:text="@string/label_cosecha_venta" android:textColor="#6b7280" android:textSize="14sp"/>
                            <TextView android:id="@+id/tvCostoCosecha" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="S/ 0" android:textColor="#f59e0b" android:textStyle="bold" android:textSize="14sp"/>
                        </RelativeLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="#f0fdf4"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#d1fae5"
                            app:strokeWidth="1dp">
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_ganancia_neta"
                                    android:textColor="#166534"
                                    android:textStyle="bold"
                                    android:textSize="16sp"/>
                                <TextView
                                    android:id="@+id/tvGananciaNeta"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentEnd="true"
                                    android:text="+S/ 0.00"
                                    android:textColor="#166534"
                                    android:textStyle="bold"
                                    android:textSize="16sp"/>
                            </RelativeLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Labores -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvLaboresTitulo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_labores"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <Button
                    android:id="@+id/btnAgregarLabor"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_agregar"
                    android:textAllCaps="false"
                    android:textColor="#15803d" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLabores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_labor_detalle" />

            <!-- Cosechas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvCosechasTitulo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_cosecha"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <Button
                    android:id="@+id/btnAgregarCosecha"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_registrar"
                    android:textAllCaps="false"
                    android:textColor="#15803d" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCosechas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_cosecha_detalle" />

            <Button
                android:id="@+id/btnEliminarCultivo"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#fee2e2"
                android:text="@string/btn_eliminar_cultivo"
                android:textAllCaps="false"
                android:textColor="#b91c1c"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconTint="#b91c1c" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_casa"
                app:tint="#9ca3af" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_inicio"
                android:textSize="10sp"
                android:textColor="#9ca3af" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navTerrenos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_ubicacion_terreno"
                app:tint="#9ca3af" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_terrenos"
                android:textSize="10sp"
                android:textColor="#9ca3af" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCultivos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/agro_planta_buena"
                app:tint="#166534" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_cultivos"
                android:textSize="10sp"
                android:textColor="#166534"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navLabores"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_lista"
                app:tint="#9ca3af" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_labores"
                android:textSize="10sp"
                android:textColor="#9ca3af" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navReportes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_estadistica_01"
                app:tint="#9ca3af" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_reportes"
                android:textSize="10sp"
                android:textColor="#9ca3af" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
