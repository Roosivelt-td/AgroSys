<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/header_gradient"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginStart="70dp"
                android:layout_marginEnd="70dp"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivTitleLogo"
                    android:layout_width="100dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/title_03" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Agricultura\nInteligente"
                    android:textSize="12sp"
                    android:layout_gravity="center"
                    android:textColor="#ffffff"
                    android:layout_marginBottom="2dp"/>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="30dp"
                app:cardElevation="15dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Progress Indicator -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginBottom="24dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/circle_bg_green_light"
                                android:backgroundTint="#166534"
                                android:gravity="center"
                                android:text="✓"
                                android:textColor="@android:color/white"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Personales"
                                android:textSize="10sp"
                                android:textColor="#166534" />
                        </LinearLayout>

                        <View
                            android:layout_width="40dp"
                            android:layout_height="2dp"
                            android:background="#166534"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvStep2Circle"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/circle_bg_green_light"
                                android:backgroundTint="#166534"
                                android:gravity="center"
                                android:text="2"
                                android:textColor="@android:color/white"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Información"
                                android:textSize="10sp"
                                android:textColor="#166534" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Crear Cuenta"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_gravity="center"
                        android:textColor="#1F2937"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Información agrícola"
                        android:textSize="14sp"
                        android:layout_gravity="center"
                        android:textColor="#6B7280"
                        android:layout_marginBottom="24dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rol en la plataforma"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleRoleGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:checkedButton="@+id/btnRoleAgri"
                        app:selectionRequired="true"
                        app:singleSelection="true">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRoleAgri"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Agricultor"
                            android:textAllCaps="false"
                            android:textSize="11sp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRoleSuper"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Supervisor"
                            android:textAllCaps="false"
                            android:textSize="11sp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRoleAdmin"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Admin"
                            android:textAllCaps="false"
                            android:textSize="11sp" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <EditText
                        android:id="@+id/etRegDni"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/edit_text_elegant"
                        android:hint="DNI / Documento"
                        android:inputType="number"
                        android:paddingHorizontal="12dp"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etRegExp"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/edit_text_elegant"
                        android:hint="Años de experiencia"
                        android:inputType="number"
                        android:paddingHorizontal="12dp"
                        android:textSize="14sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:boxStrokeWidth="0dp"
                        app:hintEnabled="false">
                        <AutoCompleteTextView
                            android:id="@+id/spinnerEducation"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/edit_text_elegant"
                            android:hint="Nivel educativo"
                            android:inputType="none"
                            android:paddingHorizontal="12dp"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <EditText
                        android:id="@+id/etRegOrg"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/edit_text_elegant"
                        android:hint="Organización / Finca"
                        android:paddingHorizontal="12dp"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBackStep"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Atrás"
                            android:textAllCaps="false"
                            app:cornerRadius="12dp"
                            app:strokeColor="#D1D5DB" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFinalizeRegister"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:backgroundTint="#a15fc1"
                            android:text="Registrarse"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            app:cornerRadius="12dp" />
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="5dp"
                android:text="🛡 Tus datos están seguros"
                android:textColor="#9CA3AF"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>