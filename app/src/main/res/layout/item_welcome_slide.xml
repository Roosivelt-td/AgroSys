<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ffffff"
    android:padding="1dp">

    <!-- 1. Logo Circular (Top) -->
    <ImageView
        android:id="@+id/ivLogoTop"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="32dp"
        android:src="@drawable/logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2. Brand Block -->
    <LinearLayout
        android:id="@+id/llBrandBlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivLogoTop">

        <ImageView
            android:id="@+id/ivTitleLogo"
            android:layout_width="300dp"
            android:layout_height="40dp"
            android:scaleType="fitCenter"
            android:src="@drawable/title_02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="— Agricultura inteligente —"
            android:textColor="#1F2937"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 3. Icon Block -->
    <LinearLayout
        android:id="@+id/llIconBlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llBrandBlock">

        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/circle_bg_green_light"
            android:padding="20dp">

            <ImageView
                android:id="@+id/ivMainIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_planta_buena"
                app:tint="#15803d" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Gestion de Agricultura inteligente"
            android:textColor="#1F2937"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 4. Text Content Area -->
    <LinearLayout
        android:id="@+id/llTextContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llIconBlock"
        app:layout_constraintVertical_bias="0.3">

        <TextView
            android:id="@+id/tvMainTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="¡Bienvenido a AgroSys!"
            android:textColor="#111827"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Tu aliado inteligente para la gestión agrícola"
            android:textColor="#6B7280"
            android:textSize="14sp" />

        <!-- Green Line Decor -->
        <View
            android:layout_width="80dp"
            android:layout_height="4dp"
            android:layout_marginTop="32dp"
            android:background="#15803d" />

        <TextView
            android:id="@+id/tvFooterText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center"
            android:text="Controla tus cultivos, terrenos y finanzas desde un solo lugar"
            android:textColor="#9CA3AF"
            android:textSize="12sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
