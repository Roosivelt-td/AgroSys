<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8fafc"
    tools:ignore="TooManyViews">

    <!-- Header Section Estandarizado -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient_bg"
        android:elevation="6dp"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/llHeaderActions"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/ivSaludoIcono"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌅"
                        android:textSize="18sp" />
                    <TextView
                        android:id="@+id/saludoTexto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/saludo_buenos_dias"
                        android:textColor="#dcfce7"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvWelcomeUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nombre_usuario_placeholder"
                    android:textColor="#ffffff"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserInfoLine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/user_info_placeholder"
                    android:textColor="#dcfce7"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llHeaderActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <!-- Mensajes -->
                <FrameLayout
                    android:id="@+id/btnMessages"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/stat_notify_chat"
                        app:tint="#ffffff" />
                    <TextView
                        android:id="@+id/smsCount"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/circle_bg_red"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="#ffffff"
                        android:textSize="8sp"
                        android:visibility="gone" />
                </FrameLayout>

                <!-- Notificaciones -->
                <FrameLayout
                    android:id="@+id/btnNotifications"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_popup_reminder"
                        app:tint="#ffffff" />
                    <TextView
                        android:id="@+id/notifCount"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/circle_bg_red"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="#ffffff"
                        android:textSize="8sp" />
                </FrameLayout>

                <!-- Perfil -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnProfileCard"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/ivUserAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_perfil"
                        android:padding="6dp"
                        android:scaleType="centerCrop"
                        app:tint="#00582a" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </RelativeLayout>

        <!-- KPI Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">
            <!-- Stat 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="10dp"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvStatCultivos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_zero" android:textStyle="bold" android:textSize="16sp" android:textColor="#1e293b"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_cultivos" android:textSize="10sp" android:textColor="#64748b"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- Stat 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="10dp"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvStatTerrenos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_zero" android:textStyle="bold" android:textSize="16sp" android:textColor="#1e293b"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_terrenos" android:textSize="10sp" android:textColor="#64748b"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- Stat 3 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="10dp"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvStatProfit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_currency_zero" android:textStyle="bold" android:textSize="16sp" android:textColor="#00582a" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_ganancia" android:textSize="10sp" android:textColor="#64748b"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/header_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tarjeta del Clima -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvWeatherCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#e2e8f0">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="#FFFFFF">
                    <ImageView
                        android:id="@+id/ivWeatherIcon"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_weather_default" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView android:id="@+id/tvCityName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/weather_loading" android:textStyle="bold" android:textColor="#1e293b" />
                        <TextView android:id="@+id/tvTemperature" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°C" android:textColor="#00582a" android:textSize="20sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvWeatherDescription" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="12sp" android:textColor="#64748b" />
                    </LinearLayout>
                    <ProgressBar
                        android:id="@+id/progressWeather"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Actions Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:columnCount="4">
                <LinearLayout android:id="@+id/navTerrenoQuick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@drawable/ic_ubicacion_terreno" app:tint="#00582a" android:background="@drawable/circle_bg_green_light" android:padding="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_terreno" android:textSize="11sp" android:layout_marginTop="4dp" android:textColor="#1e293b"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/navCultivoQuick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@drawable/agro_planta_buena" app:tint="#00582a" android:background="@drawable/circle_bg_green_light" android:padding="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_cultivo" android:textSize="11sp" android:layout_marginTop="4dp" android:textColor="#1e293b"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/navLaborQuick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@drawable/ic_lista" app:tint="#00582a" android:background="@drawable/circle_bg_green_light" android:padding="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_labor" android:textSize="11sp" android:layout_marginTop="4dp" android:textColor="#1e293b"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/navCosechaQuick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@drawable/agro_cosecha" app:tint="#00582a" android:background="@drawable/circle_bg_green_light" android:padding="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_cosecha" android:textSize="11sp" android:layout_marginTop="4dp" android:textColor="#1e293b"/>
                </LinearLayout>
            </GridLayout>

            <!-- Admin Panel -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvAdminPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#dcfce7"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#f0fdf4">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_admin"
                            app:tint="#00582a" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/label_admin_panel"
                            android:textColor="#111827"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnManageCatalogs"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_cultivos"
                            android:textAllCaps="false"
                            android:textColor="#00582a"
                            android:textSize="12sp"
                            app:icon="@drawable/agro_planta_buena"
                            app:iconSize="18dp"
                            app:iconTint="#00582a" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnManageUsers"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_usuarios"
                            android:textAllCaps="false"
                            android:textColor="#00582a"
                            android:textSize="12sp"
                            app:icon="@drawable/ic_perfil"
                            app:iconSize="18dp"
                            app:iconTint="#00582a" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Resumen Financiero -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#e2e8f0">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFFFFF">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_resumen_financiero" android:textStyle="bold" android:textColor="#1e293b" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:id="@+id/ingresosTotales" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_currency_zero" android:textColor="#00582a" android:textStyle="bold" android:textSize="14sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_ingresos" android:textSize="9sp" android:textColor="#64748b" android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:id="@+id/costosTotales" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_currency_zero" android:textColor="#dc2626" android:textStyle="bold" android:textSize="14sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_costos" android:textSize="9sp" android:textColor="#64748b" android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:id="@+id/netoTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_currency_zero" android:textStyle="bold" android:textSize="14sp" android:textColor="#1e293b" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_neto" android:textSize="9sp" android:textColor="#64748b" android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/mensajeNotificacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_notification_gradient"
                android:padding="12dp"
                android:text="@string/msg_bienvenida"
                android:textSize="12sp"
                android:textColor="#00582a" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Estandarizado -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_casa"
                app:tint="#00582a" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_inicio"
                android:textSize="10sp"
                android:textColor="#00582a"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navTerrenos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_ubicacion_terreno"
                app:tint="#9ca3af" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_terrenos"
                android:textSize="10sp"
                android:textColor="#9ca3af" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCultivos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/agro_planta_buena"
                app:tint="#9ca3af" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_cultivos"
                android:textSize="10sp"
                android:textColor="#9ca3af" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navLabores"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_lista"
                app:tint="#9ca3af" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_labores"
                android:textSize="10sp"
                android:textColor="#9ca3af" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navReportes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_estadistica_01"
                app:tint="#9ca3af" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_reportes"
                android:textSize="10sp"
                android:textColor="#9ca3af" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
