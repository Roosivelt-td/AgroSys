<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8f5ef"
    tools:ignore="TooManyViews">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/header_gradient_bg"
                android:elevation="6dp"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="10dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/llHeaderActions"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:id="@+id/ivSaludoIcono"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌅"
                                android:textSize="18sp" />
                            <TextView
                                android:id="@+id/saludoTexto"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="@string/saludo_buenos_dias"
                                android:textColor="#dcfce7"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvWelcomeUser"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nombre_usuario_placeholder"
                            android:textColor="#ffffff"
                            android:textSize="25sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvUserInfoLine"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/user_info_placeholder"
                            android:textColor="#dcfce7"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llHeaderActions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal">

                        <!-- Mensajes -->
                        <FrameLayout
                            android:id="@+id/btnMessages"
                            android:layout_width="44dp"
                            android:layout_height="44dp">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/stat_notify_chat"
                                app:tint="#ffffff" />
                            <TextView
                                android:id="@+id/smsCount"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="top|end"
                                android:background="@drawable/circle_bg_red"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="#ffffff"
                                android:textSize="9sp"
                                android:visibility="gone" />
                        </FrameLayout>

                        <!-- Notificaciones -->
                        <FrameLayout
                            android:id="@+id/btnNotifications"
                            android:layout_width="44dp"
                            android:layout_height="44dp">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_popup_reminder"
                                app:tint="#ffffff" />
                            <TextView
                                android:id="@+id/notifCount"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="top|end"
                                android:background="@drawable/circle_bg_red"
                                android:gravity="center"
                                android:text="3"
                                android:textColor="#ffffff"
                                android:textSize="9sp" />
                        </FrameLayout>

                        <!-- Perfil -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnProfileCard"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center_vertical"
                            app:cardCornerRadius="15dp">
                            <ImageView
                                android:id="@+id/btnProfile"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_perfil"
                                android:padding="4dp"
                                app:tint="#15803d" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </RelativeLayout>

                <!-- KPI Cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">
                    <!-- Stat 1 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="10dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:padding="8dp"
                            android:orientation="vertical">
                            <TextView android:id="@+id/tvStatCultivos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textSize="16sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cultivos" android:textSize="10sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <!-- Stat 2 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="10dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:padding="8dp"
                            android:orientation="vertical">
                            <TextView android:id="@+id/tvStatTerrenos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textSize="16sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Terrenos" android:textSize="10sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <!-- Stat 3 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.5"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="10dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:padding="8dp"
                            android:orientation="vertical">
                            <TextView android:id="@+id/tvStatProfit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S/0.00" android:textStyle="bold" android:textSize="16sp" android:textColor="#16a34a" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ganancia" android:textSize="10sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Tarjeta del Clima -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvWeatherCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivWeatherIcon"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/ic_weather_default" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            <TextView android:id="@+id/tvCityName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cargando..." android:textStyle="bold" />
                            <TextView android:id="@+id/tvTemperature" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°C" android:textColor="#16a34a" android:textSize="20sp" android:textStyle="bold" />
                            <TextView android:id="@+id/tvWeatherDescription" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="12sp" />
                        </LinearLayout>
                        <ProgressBar
                            android:id="@+id/progressWeather"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Quick Actions Grid -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:columnCount="4">
                    <LinearLayout android:id="@+id/navTerrenoQuick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_ubicacion_terreno" app:tint="#16a34a" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Terreno" android:textSize="10sp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/navCultivoQuick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_planta_buena" app:tint="#16a34a" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cultivo" android:textSize="10sp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/navLaborQuick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_lista" app:tint="#16a34a" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Labor" android:textSize="10sp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/navCosechaQuick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_cosecha" app:tint="#16a34a" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cosecha" android:textSize="10sp" />
                    </LinearLayout>
                </GridLayout>

                <!-- Resumen Financiero -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_resumen_financiero" android:textStyle="bold" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                                <TextView android:id="@+id/ingresosTotales" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S/0" android:textColor="#16a34a" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="INGRESOS" android:textSize="8sp" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                                <TextView android:id="@+id/costosTotales" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S/0" android:textColor="#dc2626" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="COSTOS" android:textSize="8sp" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                                <TextView android:id="@+id/netoTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S/0" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NETO" android:textSize="8sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/mensajeNotificacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_notification_gradient"
                    android:padding="12dp"
                    android:text="@string/msg_bienvenida"
                    android:textSize="12sp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Completo -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@android:color/white"
        android:elevation="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_casa" app:tint="#166534" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inicio" android:textSize="10sp" android:textColor="#166534" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navTerrenos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_ubicacion_terreno" app:tint="#9CA3AF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Terrenos" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCultivos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_planta_buena" app:tint="#9CA3AF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cultivos" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navLabores"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_lista" app:tint="#9CA3AF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Labores" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navReportes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_estadistica_01" app:tint="#9CA3AF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reportes" android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
