                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@drawable/ic_ubicacion_terreno" app:tint="#16a34a" android:background="@drawable/circle_bg_green_light" android:padding="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_terreno" android:textSize="11sp" android:layout_marginTop="4dp" android:textColor="#1e293b"/>
