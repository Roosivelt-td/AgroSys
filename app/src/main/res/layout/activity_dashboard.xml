<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8fafc"
    tools:ignore="TooManyViews">

    <!-- Header Section Estandarizado -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient_bg"
        android:elevation="6dp"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/llHeaderActions"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/ivSaludoIcono"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌅"
                        android:textSize="18sp" />
                    <TextView
                        android:id="@+id/saludoTexto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/saludo_buenos_dias"
                        android:textColor="#dcfce7"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvWelcomeUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nombre_usuario_placeholder"
                    android:textColor="#ffffff"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserInfoLine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/user_info_placeholder"
                    android:textColor="#dcfce7"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llHeaderActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <!-- Mensajes -->
                <FrameLayout
                    android:id="@+id/btnMessages"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/stat_notify_chat"
                        app:tint="#ffffff" />
                    <TextView
                        android:id="@+id/smsCount"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/circle_bg_red"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="#ffffff"
                        android:textSize="8sp"
                        android:visibility="gone" />
                </FrameLayout>

                <!-- Notificaciones -->
                <FrameLayout
                    android:id="@+id/btnNotifications"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_popup_reminder"
                        app:tint="#ffffff" />
                    <TextView
                        android:id="@+id/notifCount"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/circle_bg_red"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="#ffffff"
                        android:textSize="8sp" />
                </FrameLayout>

                <!-- Perfil -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnProfileCard"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/ivUserAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_perfil"
                        android:padding="6dp"
                        android:scaleType="centerCrop"
                        app:tint="#15803d" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </RelativeLayout>

        <!-- KPI Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">
            <!-- Stat 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="10dp"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvStatCultivos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_zero" android:textStyle="bold" android:textSize="16sp" android:textColor="#1e293b"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_cultivos" android:textSize="10sp" android:textColor="#64748b"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- Stat 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="10dp"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvStatTerrenos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_zero" android:textStyle="bold" android:textSize="16sp" android:textColor="#1e293b"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_terrenos" android:textSize="10sp" android:textColor="#64748b"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- Stat 3 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="10dp"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvStatProfit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_currency_zero" android:textStyle="bold" android:textSize="16sp" android:textColor="#16a34a" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_ganancia" android:textSize="10sp" android:textColor="#64748b"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

    <!-- Dynamic Welcome/Action Bubble (Fuera del Scroll) -->
    <LinearLayout
        android:id="@+id/layoutWelcomeAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/welcome_bubble_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="10dp"
        android:paddingHorizontal="14dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/header_container"
        tools:visibility="visible">

        <View
            android:layout_width="4dp"
            android:layout_height="28dp"
            android:background="#16A34A" />

        <TextView
            android:id="@+id/tvWelcomeActionIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" 🌾 "
            android:textSize="16sp"
            android:layout_marginStart="8dp"/>

        <TextView
            android:id="@+id/tvWelcomeActionMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="¡Bienvenido! Comienza registrando tus Terrenos."
            android:textColor="#166534"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnCloseWelcomeAction"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#166534"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/layoutWelcomeAction">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Weather Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvWeatherCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#e2e8f0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFFFFF">

                    <!-- Weather row -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/llTempContainer"
                            android:orientation="horizontal"
                            android:gravity="top"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginTop="2dp"
                                android:src="@drawable/ic_ubicacion"
                                app:tint="#EF4444" />

                            <TextView
                                android:id="@+id/tvCityName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="@string/weather_loading"
                                android:textColor="#64748b"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/llTempContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTemperature"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="22°C"
                                android:textColor="#F97316"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvWeatherDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Algo de nubes"
                                android:textColor="#16A34A"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </RelativeLayout>

                    <!-- Tip Bubble -->
                    <LinearLayout
                        android:id="@+id/llWeatherTipContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/rounded_soft"
                        android:backgroundTint="#F0FDF4"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_ubicacion"
                            app:tint="#EF4444" />

                        <TextView
                            android:id="@+id/tvWeatherTip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/weather_tip_consulting"
                            android:textColor="#166534"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressWeather"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <!-- Ocultamos el icono grande del clima para seguir el modelo -->
                    <ImageView
                        android:id="@+id/ivWeatherIcon"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>



            <!-- Alerts Section -->
            <LinearLayout
                android:id="@+id/layoutAlertasAlquiler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:visibility="gone" />

            <!-- Admin Panel -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvAdminPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#dcfce7"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#f0fdf4">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_admin"
                            app:tint="#15803d" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/label_admin_panel"
                            android:textColor="#111827"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnManageCatalogs"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_cultivos"
                            android:textAllCaps="false"
                            android:textColor="#166534"
                            android:textSize="12sp"
                            app:icon="@drawable/agro_planta_buena"
                            app:iconSize="18dp"
                            app:iconTint="#166534" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnManageUsers"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_usuarios"
                            android:textAllCaps="false"
                            android:textColor="#166534"
                            android:textSize="12sp"
                            app:icon="@drawable/ic_perfil"
                            app:iconSize="18dp"
                            app:iconTint="#166534" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Resumen Financiero Moderno -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#e2e8f0">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_estadistica_01"
                            app:tint="#15803d" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/label_resumen_financiero"
                            android:textStyle="bold"
                            android:textColor="#1e293b"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Ingresos -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/rounded_soft"
                            android:backgroundTint="#F0FDF4"
                            android:gravity="center"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_ingresos"
                                android:textSize="10sp"
                                android:textColor="#16a34a"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/tvIngresosDash"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="S/ 0.00"
                                android:textColor="#15803D"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- Costos -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="4dp"
                            android:background="@drawable/rounded_soft"
                            android:backgroundTint="#FEF2F2"
                            android:gravity="center"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_costos"
                                android:textSize="10sp"
                                android:textColor="#dc2626"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/tvCostosDash"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="S/ 0.00"
                                android:textColor="#DC2626"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- Neto -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/rounded_soft"
                            android:backgroundTint="#FFF7ED"
                            android:gravity="center"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_neto"
                                android:textSize="10sp"
                                android:textColor="#ea580c"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/tvNetoDash"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="S/ 0.00"
                                android:textColor="#C2410C"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Cultivos en Curso Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#e2e8f0">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/agro_planta_hoja"
                            app:tint="#15803d" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/label_cultivos_en_curso"
                            android:textStyle="bold"
                            android:textColor="#1e293b"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/btnVerTodosCultivos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ver todos →"
                            android:textColor="#15803d"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:padding="4dp" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCultivosEnCurso"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_cultivo_curso"
                        tools:itemCount="3" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Producción Reciente Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#e2e8f0">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Producción reciente (kg)"
                            android:textStyle="bold"
                            android:textColor="#1e293b"
                            android:textSize="16sp" />
                        <TextView
