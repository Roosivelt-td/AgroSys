<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_bg"
    android:padding="20dp">

    <!-- Header Simplificado -->
    <LinearLayout
        android:id="@+id/dialogHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvFormLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DETALLES DE LA LABOR"
            android:textColor="#15803D"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:background="@drawable/rounded_soft"
            android:backgroundTint="#DCFCE7"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:layout_marginBottom="8dp" />
    </LinearLayout>

    <!-- Contenido con Scroll -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:fillViewport="true"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toTopOf="@id/dialogFooter"
        app:layout_constraintTop_toBottomOf="@id/dialogHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/tvLabelFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Fecha de realización"
                android:textColor="#374151"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etFecha"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/edit_text_elegant"
                android:clickable="true"
                android:focusable="false"
                android:hint="dd/mm/aaaa"
                android:paddingHorizontal="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Descripción / Notas"
                android:textColor="#374151"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/edit_text_elegant"
                android:hint="Ej. Se aplicó abono foliar..."
                android:minLines="2"
                android:padding="12dp"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Costos de mano de obra (Peones)"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Sección Varones -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/rounded_soft"
                android:backgroundTint="#F0F9FF"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VARONES" android:textColor="#0369A1" android:textStyle="bold" android:textSize="11sp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cant. Personas" android:textSize="10sp"/>
                        <EditText android:id="@+id/etVaronCant" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_elegant" android:inputType="number" android:text="0" android:gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:layout_marginStart="8dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pago" android:textSize="10sp"/>
                        <EditText android:id="@+id/etVaronCosto" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_elegant" android:inputType="numberDecimal" android:text="0.00" android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Sección Mujeres -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_soft"
                android:backgroundTint="#FDF2F8"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MUJERES" android:textColor="#BE185D" android:textStyle="bold" android:textSize="11sp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cant. Personas" android:textSize="10sp"/>
                        <EditText android:id="@+id/etMujerCant" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_elegant" android:inputType="number" android:text="0" android:gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:layout_marginStart="8dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pago" android:textSize="10sp"/>
                        <EditText android:id="@+id/etMujerCosto" android:layout_width="match_parent" android:layout_height="40dp" android:background="@drawable/edit_text_elegant" android:inputType="numberDecimal" android:text="0.00" android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Maquinaria -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gasto en Maquinaria / Otros (S/)" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                <EditText android:id="@+id/etCostoMaq" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="6dp" android:background="@drawable/edit_text_elegant" android:inputType="numberDecimal" android:text="0.00" android:paddingHorizontal="16dp" />
            </LinearLayout>

            <!-- Foto de Evidencia -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Evidencia Fotográfica"
                android:textColor="#374151"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFotoLabor"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F3F1F8"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivFotoLabor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:src="@drawable/uploap"
                        android:padding="1dp"
                        app:tint="#D1D5DB" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRemoveFoto"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="12dp"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        app:icon="@drawable/ic_close"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="18dp"
                        app:iconTint="#ffffff"
                        android:backgroundTint="#EF4444"
                        app:cornerRadius="16dp"
                        android:visibility="gone" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Footer Fijo -->
    <LinearLayout
        android:id="@+id/dialogFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Subtotal Labor:" android:textColor="#374151" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvLaborSubtotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S/ 0.00" android:textColor="#15803D" android:textSize="18sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="CANCELAR"
                android:textColor="#6B7280" />
            <Button
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:backgroundTint="#15803D"
                android:text="ACEPTAR"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
