<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#E5E7EB"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/spinnerCategoriaInsumo"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/edit_text_elegant" />

            <ImageView
                android:id="@+id/btnDeleteInsumo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#EF4444" />
        </LinearLayout>

        <AutoCompleteTextView
            android:id="@+id/etNombreInsumo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/edit_text_elegant"
            android:hint="Nombre del insumo (ej: Urea, Glifosato)"
            android:paddingHorizontal="12dp"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cant." android:textColor="#6B7280" android:textSize="11sp" />
                <EditText android:id="@+id/etInsumoCantidad" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/edit_text_elegant" android:hint="0.0" android:inputType="numberDecimal" android:paddingHorizontal="10dp" android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Unidad" android:textColor="#6B7280" android:textSize="11sp" />
                <EditText android:id="@+id/etUnidadMedida" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/edit_text_elegant" android:hint="Kg/Lt" android:paddingHorizontal="10dp" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="P. Unit" android:textColor="#6B7280" android:textSize="11sp" />
                <EditText android:id="@+id/etInsumoPrecio" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/edit_text_elegant" android:hint="0.00" android:inputType="numberDecimal" android:paddingHorizontal="10dp" android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <CheckBox
            android:id="@+id/cbTieneProveedor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="¿Especificar proveedor?"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/llProveedorContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <EditText
                android:id="@+id/etNombreProveedor"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/edit_text_elegant"
                android:hint="Nombre del proveedor / Empresa"
                android:paddingHorizontal="12dp"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvInsumoTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:text="Total: S/ 0.00"
            android:textColor="#111827"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
