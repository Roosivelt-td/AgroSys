<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Capa de sombra simulada (un poco más grande y desplazada hacia abajo) -->
    <item
        android:top="2dp"
        android:left="0.5dp"
        android:right="0.5dp">
        <shape>
            <solid android:color="#25000000" />
            <corners android:bottomLeftRadius="33dp" android:bottomRightRadius="33dp" />
        </shape>
    </item>

    <!-- Capa principal con el degradado original -->
    <item android:bottom="3dp">
        <shape>
            <gradient
                android:angle="135"
                android:endColor="#00582a"
                android:startColor="#15803d"
                android:type="linear" />
            <!--<corners android:bottomLeftRadius="32dp" android:bottomRightRadius="32dp" />-->
        </shape>
    </item>
</layer-list>